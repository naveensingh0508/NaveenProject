# Put this file at: backend/.env
# Gemini API configuration
GEMINI_API_KEY=your_gemini_api_key_here
# Alternative key name supported by Google SDK
# GOOGLE_API_KEY=your_gemini_api_key_here

# Primary model for full notes generation
GEMINI_MODEL=gemini-3-flash-preview

# Optional model for transcript chunk summarization
# GEMINI_SUMMARY_MODEL=gemini-3-flash-preview

# Transcript length handling
MAX_TRANSCRIPT_CHARS=12000
TRANSCRIPT_CHUNK_SIZE=12000
TRANSCRIPT_CHUNK_OVERLAP=500
TRANSCRIPT_MAX_CHUNKS=8

# Optional: YouTube transcript proxy settings (recommended on Render if IP gets blocked)
# WEBSHARE_PROXY_USERNAME=your_webshare_username
# WEBSHARE_PROXY_PASSWORD=your_webshare_password
# WEBSHARE_PROXY_LOCATIONS=us,in
# YT_PROXY_RETRIES=10

# Optional: generic proxy URLs (use instead of Webshare fields above)
# YT_PROXY_HTTP_URL=http://username:password@host:port
# YT_PROXY_HTTPS_URL=http://username:password@host:port

# Mobile OTP settings
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
# Demo mode: true = OTP shown in response, false = real SMS via provider below
OTP_DEBUG_MODE=false

# Provider config
SMS_PROVIDER=twilio
# If user types 10 digits without +country code, this country code is prefixed.
OTP_DEFAULT_COUNTRY_CODE=+91

# Twilio config (required when OTP_DEBUG_MODE=false)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Use one of these sender options:
TWILIO_FROM_NUMBER=+1415XXXXXXX
# TWILIO_MESSAGING_SERVICE_SID=MGXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
